<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Venda de Máquina de Costura</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body { font-family: Arial, sans-serif; margin: 0; background: #f4f6f7; }
        .container { max-width: 800px; margin: 40px auto; background: #fff; padding: 24px; border-radius: 10px; box-shadow: 0 0 10px #bbb; }
        h1 { color: #22577a; margin-bottom: 0.5em; }
        .tabs { display: flex; border-bottom: 2px solid #e0e0e0; margin-bottom: 20px; }
        .tab-btn {
            background: none;
            border: none;
            outline: none;
            padding: 14px 30px 10px 30px;
            font-size: 1.1em;
            cursor: pointer;
            color: #888;
            border-bottom: 3px solid transparent;
            transition: color 0.2s, border-bottom 0.2s;
        }
        .tab-btn.active {
            color: #22577a;
            border-bottom: 3px solid #22577a;
            font-weight: bold;
        }
        .tab-content { display: none; padding: 12px 0 0 0; }
        .tab-content.active { display: block; }
        .gallery { display: flex; gap: 18px; margin-top: 10px; flex-wrap: wrap; }
        .gallery img { width: 180px; border-radius: 6px; box-shadow: 0 2px 8px #ddd; }
        .features ul { margin: 0; padding-left: 18px; }
        .price { font-size: 2em; color: #27ae60; margin: 20px 0; }
        .contact input, .contact textarea {
            width: 100%; padding: 8px; margin-bottom: 10px; border: 1px solid #ccc; border-radius: 4px;
        }
        .contact button, .whatsapp {
            background: #25d366; color: #fff; padding: 12px 24px;
            border: none; border-radius: 4px; font-size: 1em; cursor: pointer; text-decoration: none;
        }
        .contact button:hover, .whatsapp:hover { background: #1ebe57; }
        @media (max-width: 600px) {
            .gallery { flex-direction: column; align-items: center; }
            .gallery img { width: 90%; }
            .container { padding: 10px; }
            .tabs { flex-direction: column; }
            .tab-btn { width: 100%; text-align: left; }
        }
    </style>
    <script>
        function showTab(tabIndex) {
            const tabs = document.querySelectorAll('.tab-btn');
            const contents = document.querySelectorAll('.tab-content');
            tabs.forEach((tab, idx) => {
                tab.classList.toggle('active', idx === tabIndex);
                contents[idx].classList.toggle('active', idx === tabIndex);
            });
        }
        window.onload = function() {
            showTab(0);
            document.querySelectorAll('.tab-btn').forEach((tab, idx) => {
                tab.onclick = () => showTab(idx);
            });
        };
    </script>
</head>
<body>
    <div class="container">
        <h1>Máquina de Costura Profissional</h1>
        <div class="tabs">
            <button class="tab-btn active">Mostruário</button>
            <button class="tab-btn">Características</button>
            <button class="tab-btn">Preço</button>
            <button class="tab-btn">Contato</button>
        </div>

        <div class="tab-content active">
            <h2>Mostruário</h2>
            <div class="gallery">
                <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb" alt="Máquina de Costura 1">
                <img src="https://images.unsplash.com/photo-1519125323398-675f0ddb6308" alt="Máquina de Costura 2">
                <img src="https://images.unsplash.com/photo-1464983953574-0892a716854b" alt="Máquina de Costura 3">
            </div>
        </div>
        <div class="tab-content">
            <h2>Características</h2>
            <div class="features">
                <ul>
                    <li>Costura reta e zig-zag</li>
                    <li>Velocidade ajustável</li>
                    <li>Motor silencioso</li>
                    <li>Painel digital</li>
                    <li>Garantia de 1 ano</li>
                    <li>Suporte técnico incluso</li>
                </ul>
            </div>
        </div>
        <div class="tab-content">
            <h2>Preço</h2>
            <div class="price"><strong>R$ 1.200,00</strong></div>
            <p>Parcelamento em até 10x sem juros.</p>
            <a class="whatsapp" href="https://wa.me/SEUNUMERO?text=Tenho%20interesse%20na%20máquina%20de%20costura!" target="_blank">
                Fale pelo WhatsApp
            </a>
        </div>
        <div class="tab-content">
            <h2>Contato</h2>
            <form class="contact" action="mailto:seuemail@exemplo.com" method="post" enctype="text/plain">
                <input type="text" name="nome" placeholder="Seu nome" required>
                <input type="email" name="email" placeholder="Seu e-mail" required>
                <textarea name="mensagem" rows="4" placeholder="Sua mensagem" required></textarea>
                <button type="submit">Enviar</button>
            </form>
        </div>
    </div>
</body>
</html>